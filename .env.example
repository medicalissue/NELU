# Runtime environment for Gate Normalization experiments.
# Copy to `.env`, fill in the values, and `source .env` before any of
# the scripts/infra/*.sh helpers. AWS credentials come from the standard
# AWS CLI config — they do NOT live in this file.

# ── Weights & Biases ───────────────────────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=gate-normalization
WANDB_ENTITY=

# ── Object storage ─────────────────────────────────────────────────
# Dataset bucket (workers read; one-off ops write via the data instance)
# and checkpoint/lease bucket (workers read+write).
DATA_BUCKET=s3://nelu-datasets
CKPT_BUCKET=s3://nelu-checkpoints

# Pre-built worker venv tarball, fetched at boot by scripts/bootstrap.sh.
VENV_S3_URL=s3://nelu-datasets/env/nelu-venv-py310-cu130.tar.gz

# EBS snapshot containing the dataset volume. Workers mount a fresh
# copy of this snapshot at /data via BlockDeviceMappings.
DATA_SNAPSHOT=snap-0adfaa42ce378623c

# ── Campaign controls ──────────────────────────────────────────────
# Ordered list of AZs the watchdog rotates through when launching spot
# workers. First AZ is tried first; if every AZ rejects the request the
# watchdog sleeps CAPACITY_SLEEP_SEC and starts over. Only these AZs
# are used — us-west-2d is typically cheapest for p5.
CAMPAIGN_AZS="us-west-2d us-west-2c us-west-2b us-west-2a"

TARGET_WORKERS=2
INSTANCE_TYPE=p5.48xlarge

# ── AWS region hint ────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-west-2
