# Runtime environment for Gate Normalization experiments.
#
# Copy to `.env`, fill in the values, and `source .env` (or rely on your
# shell / direnv to load it). SkyPilot reads AWS credentials from the
# standard AWS CLI configuration, so AWS keys are *not* kept here.

# ── Weights & Biases ───────────────────────────────────────────────
# Required when passing `--log-wandb` to the trainer.
WANDB_API_KEY=
WANDB_PROJECT=gate-normalization
WANDB_ENTITY=

# ── Object storage ─────────────────────────────────────────────────
# Datasets and long-lived checkpoint stores. Both are mounted into the
# SkyPilot worker's filesystem so the trainer sees them as local paths.
DATA_BUCKET=s3://imagenet-1k
CKPT_BUCKET=s3://gate-norm-checkpoints

# ── Optional ──────────────────────────────────────────────────────
# Uncomment to authenticate with the HuggingFace Hub (gated datasets /
# private model pushes). Not required for the paper reproductions.
# HF_TOKEN=
