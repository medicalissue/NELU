# AWS
AWS_REGION=us-west-2
S3_BUCKET=s3://nelu-datasets
DATA_SOURCE_S3=s3://nelu-datasets
SECURITY_GROUP=sg-xxxxxxxxxxxxxxxxx
SUBNETS=subnet-aaaaaaaaaaaaaaaaa,subnet-bbbbbbbbbbbbbbbbb,subnet-ccccccccccccccccc,subnet-ddddddddddddddddd
# SUBNET=subnet-xxxxxxxxxxxxxxxxx
IAM_INSTANCE_PROFILE=arn:aws:iam::123456789012:instance-profile/InstanceRole
KEY_NAME=your-keypair

# Snapshot / launch
# launch_snapshot_setup.sh fills DATA_SNAPSHOT automatically.
DATA_SNAPSHOT=
INSTANCE_TYPE=p5.48xlarge
MAX_SPOT_PRICE=30.00
SPOT_RETRY_INTERVAL=60

# Tracking
WANDB_API_KEY=

# Optional AMI override
# AMI=
# AMI_SSM_PARAM=/aws/service/deeplearning/ami/x86_64/base-oss-nvidia-driver-gpu-ubuntu-22.04/latest/ami-id
