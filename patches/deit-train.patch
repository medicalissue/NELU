 import utils
 
+# NELU paper: import our activations + define recursive swap helper.
+# `nelu` package must be importable; the launcher (ResAct/run_h100.sh)
+# prepends ResAct to PYTHONPATH for this run.
+import torch.nn as _nn
+from nelu import NELU as _NELU, NiLU as _NiLU
+
+_ACT_CLS_MAP = {
+    "gelu": _nn.GELU,
+    "silu": _nn.SiLU,
+    "nelu": _NELU,
+    "nilu": _NiLU,
+}
+
+def _infer_act_channels(parent, act_name):
+    """Return the feature dim an activation instance sees.
+
+    Walks the parent module's direct children in definition order.
+    When we hit `act_name`, the most recently-seen `out_features`
+    (from Linear / Conv2d) is the activation's channel dim.
+    For timm Mlp: fc1 → act → drop1 → fc2  → fc1.out_features.
+    For ConvNeXt Block: pwconv1 → act → pwconv2  → pwconv1.out_features.
+    """
+    last_out = None
+    for name, child in parent.named_children():
+        if hasattr(child, "out_features"):
+            last_out = child.out_features
+        elif isinstance(child, (_nn.Conv2d, _nn.Conv1d, _nn.Conv3d)):
+            last_out = child.out_channels
+        if name == act_name:
+            return last_out
+    return None
+
+
+def _replace_act(module, baseline_cls, target_cls, needs_channels):
+    """Recursively replace every `baseline_cls` instance with `target_cls(...)`.
+
+    If `needs_channels` is True the target class is instantiated with
+    `target_cls(num_channels)` after inferring the channel count from
+    the parent module.
+    """
+    for name, child in module.named_children():
+        if isinstance(child, baseline_cls):
+            if needs_channels:
+                C = _infer_act_channels(module, name)
+                if C is None:
+                    raise RuntimeError(
+                        f"Could not infer channel count for {type(module).__name__}.{name}")
+                setattr(module, name, target_cls(C))
+            else:
+                setattr(module, name, target_cls())
+        else:
+            _replace_act(child, baseline_cls, target_cls, needs_channels)
+    return module
+
 
