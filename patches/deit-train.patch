+# NELU paper: import our activations + define recursive swap helper.
+# `nelu` package must be importable; the launcher (ResAct/run_h100.sh)
+# prepends ResAct to PYTHONPATH for this run.
+import torch.nn as _nn
+from nelu import (NELU as _NELU, NiLU as _NiLU,
+                  NELU_SG as _NELU_SG, NiLU_SG as _NiLU_SG,
+                  NELUCUDA as _NELUCUDA, NiLUCUDA as _NiLUCUDA,
+                  NELUCUDA_SG as _NELUCUDA_SG, NiLUCUDA_SG as _NiLUCUDA_SG)
+
+_NELU_CLS    = _NELUCUDA    if _NELUCUDA    is not None else _NELU
+_NILU_CLS    = _NiLUCUDA    if _NiLUCUDA    is not None else _NiLU
+_NELU_SG_CLS = _NELUCUDA_SG if _NELUCUDA_SG is not None else _NELU_SG
+_NILU_SG_CLS = _NiLUCUDA_SG if _NiLUCUDA_SG is not None else _NiLU_SG
+_ACT_CLS_MAP = {
+    "gelu":    _nn.GELU,
+    "silu":    _nn.SiLU,
+    "nelu":    _NELU_CLS,
+    "nilu":    _NILU_CLS,
+    "nelu_sg": _NELU_SG_CLS,
+    "nilu_sg": _NILU_SG_CLS,
+}
+
+def _replace_act(module, baseline_cls, target_cls):
+    """Recursively replace every `baseline_cls` instance with `target_cls()`."""
+    for name, child in module.named_children():
+        if isinstance(child, baseline_cls):
+            setattr(module, name, target_cls())
+        else:
+            _replace_act(child, baseline_cls, target_cls)
+    return module
+
 
